<ui:FluentWindow
    x:Class="HomeVpnProxyTray.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="HomeVPN Proxy"
    Width="480"
    Height="700"
    MinWidth="420"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="HomeVPN Proxy" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,4,20,20">
            <StackPanel>

                <!-- Master switch -->
                <ui:CardControl Margin="0,0,0,16">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Power24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="HomeVPN Proxy" FontWeight="SemiBold" />
                            <TextBlock x:Name="MasterStatusText" Text="-" FontSize="12" Opacity="0.65" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="MasterToggle" Checked="OnMasterToggleChanged" Unchecked="OnMasterToggleChanged" />
                </ui:CardControl>

                <!-- Live status: local (this PC) and router-side (SSH) checks together,
                     since they're both just "is the proxy actually working" from two
                     different vantage points -->
                <TextBlock Text="Состояние" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Margin="4,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="ProxyStatusDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                            <TextBlock x:Name="ProxyStatusText" Text="Прокси: -" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="LocalCheckCommandText" Text="" FontFamily="Consolas" FontSize="10" Opacity="0.5" TextWrapping="Wrap" Margin="18,2,0,10" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="RouterCheckDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                            <TextBlock x:Name="RouterCheckStatusText" Text="Прокси на роутере (SSH): не проверялся" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="RouterCheckCommandText" Text="" FontFamily="Consolas" FontSize="10" Opacity="0.5" TextWrapping="Wrap" Margin="18,2,0,4" />
                        <TextBlock x:Name="RouterCheckDetailText" Text="" FontFamily="Consolas" FontSize="10" Opacity="0.65" TextWrapping="Wrap" Margin="18,0,0,10" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse x:Name="CheckPointStatusDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                            <TextBlock x:Name="CheckPointStatusText" Text="Check Point: -" Margin="8,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="Туннелируемые домены" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
                        <ItemsControl x:Name="DomainsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button
                                x:Name="RefreshButton"
                                Grid.Column="0"
                                Content="Проверить с ПК"
                                Appearance="Secondary"
                                Margin="0,0,6,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="OnRefreshClick" />
                            <ui:Button
                                x:Name="CheckStatusButton"
                                Grid.Column="1"
                                Content="Проверить на роутере"
                                IsEnabled="False"
                                Margin="6,0,0,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="OnCheckStatusClick" />
                        </Grid>
                        <ui:Button
                            x:Name="FixButton"
                            Content="Починить"
                            Appearance="Danger"
                            IsEnabled="False"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="OnFixClick" />
                    </StackPanel>
                </Border>

                <!-- Env vars section -->
                <TextBlock Text="Переменные окружения (CLI: Claude Code, Codex CLI, curl, git...)" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Margin="4,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="HTTP_PROXY" FontFamily="Consolas" FontWeight="SemiBold" Width="120" />
                            <TextBox x:Name="HttpProxyValueBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontFamily="Consolas" IsReadOnlyCaretVisible="True" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="HTTPS_PROXY" FontFamily="Consolas" FontWeight="SemiBold" Width="120" />
                            <TextBox x:Name="HttpsProxyValueBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontFamily="Consolas" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ALL_PROXY" FontFamily="Consolas" FontWeight="SemiBold" Width="120" />
                            <TextBox x:Name="AllProxyValueBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontFamily="Consolas" />
                        </StackPanel>
                        <TextBlock Text="HKCU\Environment" FontSize="11" Opacity="0.5" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- PAC section -->
                <TextBlock Text="PAC-скрипт (браузер)" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Margin="4,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="AutoConfigURL" FontFamily="Consolas" FontWeight="SemiBold" Width="120" />
                            <TextBox x:Name="PacUrlValueBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontFamily="Consolas" />
                        </StackPanel>
                        <TextBlock Text="HKCU\...\Internet Settings" FontSize="11" Opacity="0.5" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Router connection settings - a one-time setup step, kept
                     separate from the live status panel above -->
                <TextBlock Text="Подключение к роутеру (для проверки по SSH)" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Margin="4,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="IP" VerticalAlignment="Center" Opacity="0.8" />
                            <TextBox Grid.Column="1" x:Name="RouterHostBox" Text="192.168.2.1" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Логин" VerticalAlignment="Center" Opacity="0.8" />
                            <TextBox Grid.Column="1" x:Name="RouterUsernameBox" Text="root" />
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Пароль" VerticalAlignment="Center" Opacity="0.8" />
                            <PasswordBox Grid.Column="1" x:Name="RouterPasswordBox" PasswordChanged="OnRouterPasswordChanged" />
                        </Grid>

                        <ui:Button
                            Content="Сохранить"
                            Appearance="Secondary"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="OnSaveRouterSettingsClick" />

                        <TextBlock
                            x:Name="RepairStatusText"
                            Text="Пароль хранится зашифрованным (Windows DPAPI), только для этого пользователя на этом ПК."
                            TextWrapping="Wrap"
                            FontSize="11"
                            Opacity="0.55"
                            Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Autostart - last: a set-once-and-forget toggle, not something checked regularly -->
                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="ArrowRepeatAll24" />
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <TextBlock Text="Автозапуск с Windows" FontWeight="SemiBold" />
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="AutoStartToggle" Checked="OnAutoStartToggleChanged" Unchecked="OnAutoStartToggleChanged" />
                </ui:CardControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
